{
  "name": "workflow-garden",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "content:source": "pnpm exec velite build --clean",
    "content:build": "pnpm content:source && tsx scripts/build-content-indices.mts && tsx scripts/build-search.mts",
    "activity:generate": "tsx scripts/generate-activity-feed.mts",
    "activity:refresh": "bash scripts/run-diary-refresh.sh",
    "dev": "tsx scripts/dev.mts",
    "build": "pnpm content:build && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "proof": "tsx scripts/run-proof.mts"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "mdast-util-find-and-replace": "^3.0.2",
    "next": "16.2.1",
    "pagefind": "^1.4.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0",
    "unist-util-visit-parents": "^6.0.2",
    "velite": "^0.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
